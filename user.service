# systemd-user-sessions — Manage user login sessions

[Unit]
Description=User Login Session Manager
Documentation=man:systemd-user-sessions.service(8)
After=network.target

[Service]
Type=simple
ExecStart=/usr/lib/systemd/systemd-user-service
StandardOutput=inherit
StandardError=journal
Restart=always
RestartSec=5
# Ensure /run/systemd/ exists for the Unix domain socket
RuntimeDirectory=systemd
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
